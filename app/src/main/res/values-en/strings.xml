    <!-- Floating Window Guide -->
    <string name="guide_title">Open Floating Window Permission</string>
    <string name="guide_desc">To conveniently view parameters while shooting, OMaster needs floating window permission</string>
    <string name="guide_step_1">1. Find "Allow display over other apps" or similar option in settings page</string>
    <string name="guide_step_2">2. Turn on the switch</string>
    <string name="guide_step_3">3. Return to OMaster</string>
    <string name="guide_fail_title">If you encounter permission activation failure:</string>
    <string name="guide_fail_step_1">Go to "Settings -&gt; App Management"</string>
    <string name="guide_fail_step_2">Find OMaster app</string>
