    <!-- Privacy Policy Page -->
    <string name="privacy_title">User Agreement &amp; Privacy Policy</string>
    <string name="welcome_title">Welcome to OMaster</string>
    <string name="welcome_desc">OMaster is a color grading parameter management tool designed for OPPO/OnePlus/Realme mobile photography enthusiasts. Here, you can view, favorite, and reproduce Master Mode photography color grading parameters.</string>
    <string name="features_title">Features</string>
    <string name="features_list">• View Master Mode color grading parameters&#10;• Support multiple preset styles&#10;• Pure local operation, data stored locally&#10;• No internet required</string>
    <string name="data_collection_title">Data Collection</string>
    <string name="data_collection_desc">To provide better service, we use Umeng Analytics SDK to collect app usage data.</string>
    <string name="local_storage_title">Local Data Storage</string>
    <string name="local_storage_desc">The app stores the following data locally:&#10;&#10;• Subscription config (URL, version, etc.)&#10;• Preset image cache&#10;• User preferences (theme, language, etc.)&#10;• Favorite presets list&#10;&#10;All data is stored on your device, we do not upload your personal information.</string>
    <string name="permission_title">Permissions</string>
    <string name="permission_desc">Floating window feature requires SYSTEM_ALERT_WINDOW permission to display shooting parameters over other apps. This permission is only used to display preset parameters, and will not access your screen content or collect any data.</string>
